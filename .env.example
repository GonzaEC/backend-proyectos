# Base de datos
DB_URL=jdbc:postgresql://localhost:5432/service_projects
DB_USERNAME=postgres
DB_PASSWORD=secret

# JWT (misma clave que service-users)
JWT_SECRET=<mismo_secreto_que_service-users>

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# AWS S3 (prod)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET_NAME=sip-project-documents
S3_ENDPOINT=https://s3.amazonaws.com

# MinIO (dev local — descomentar y comentar las de arriba)
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_REGION=us-east-1
